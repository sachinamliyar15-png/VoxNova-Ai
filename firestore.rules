rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - credits: number (required)
    //   - plan: string (required)
    //   - lastResetDate: string (required)
    //   - createdAt: string
    //
    // Collection: voice_history
    // Document ID: {historyId}
    // Fields:
    //   - userId: string (required)
    //   - text: string (required)
    //   - voice_name: string
    //   - style: string
    //   - speed: number
    //   - pitch: number
    //   - language: string
    //   - timestamp: timestamp (required)
    //
    // Collection: caption_history
    // Document ID: {historyId}
    // Fields:
    //   - userId: string (required)
    //   - words: list (required)
    //   - language: string
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'credits', 'plan', 'lastResetDate']) &&
             data.uid is string &&
             data.email is string &&
             data.credits is number &&
             data.plan in ['free', 'basic', 'pro', 'elite'] &&
             data.lastResetDate is string;
    }

    function isValidVoiceHistory(data) {
      return data.keys().hasAll(['userId', 'text', 'timestamp']) &&
             data.userId is string &&
             data.text is string &&
             data.timestamp is timestamp;
    }

    function isValidCaptionHistory(data) {
      return data.keys().hasAll(['userId', 'words', 'timestamp']) &&
             data.userId is string &&
             data.words is list &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      isValidUser(request.resource.data) && 
                      request.resource.data.credits == 20000 &&
                      request.resource.data.plan == 'free';
      allow update: if isOwner(userId) && 
                      isValidUser(request.resource.data) &&
                      request.resource.data.plan == resource.data.plan &&
                      request.resource.data.uid == resource.data.uid;
    }

    match /voice_history/{historyId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidVoiceHistory(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /caption_history/{historyId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidCaptionHistory(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    match /cloned_voices/{voiceId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && 
                      request.resource.data.keys().hasAll(['uid', 'name']) &&
                      request.resource.data.name is string &&
                      request.resource.data.name.size() > 0;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
