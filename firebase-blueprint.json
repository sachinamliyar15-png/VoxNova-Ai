{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user credits, plan, and last reset date.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User photo URL" },
        "credits": { "type": "number", "description": "Current credit balance" },
        "plan": { "type": "string", "description": "Subscription plan (free, basic, pro, elite)" },
        "lastResetDate": { "type": "string", "description": "ISO date of last credit reset" },
        "createdAt": { "type": "string", "description": "Account creation date" }
      },
      "required": ["uid", "email", "credits", "plan", "lastResetDate"]
    },
    "ClonedVoice": {
      "title": "Cloned Voice",
      "description": "Stores metadata for a user's cloned voice.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID" },
        "name": { "type": "string", "description": "Custom name for the voice" },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "color": { "type": "string" },
        "description": { "type": "string" },
        "fingerprint": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "fingerprint", "createdAt"]
    },
    "VoiceHistory": {
      "title": "Voice History",
      "description": "Stores history of generated voice clips",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "voice_name": { "type": "string" },
        "style": { "type": "string" },
        "speed": { "type": "number" },
        "pitch": { "type": "number" },
        "language": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "CaptionHistory": {
      "title": "Caption History",
      "description": "Stores history of generated video captions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "words": { "type": "array", "items": { "type": "object" } },
        "language": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    },
    "/voice_history/{historyId}": {
      "schema": "VoiceHistory",
      "description": "Voice generation history"
    },
    "/caption_history/{historyId}": {
      "schema": "CaptionHistory",
      "description": "Caption generation history"
    },
    "/cloned_voices/{voiceId}": {
      "schema": "ClonedVoice",
      "description": "User's private cloned voices"
    }
  }
}
